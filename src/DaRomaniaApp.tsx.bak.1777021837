                <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                  <AnimatePresence mode="popLayout">
                    {filteredJobs.map((job) => {
                      const catColors: Record<string, string> = {
                        'Comunicare': 'bg-blue-100 text-blue-700 border-blue-200',
                        'Cercetare': 'bg-purple-100 text-purple-700 border-purple-200',
                        'Stiinta': 'bg-emerald-100 text-emerald-700 border-emerald-200',
                        'Scriere': 'bg-pink-100 text-pink-700 border-pink-200',
                        'Tehnologie': 'bg-cyan-100 text-cyan-700 border-cyan-200',
                        'Creativitate': 'bg-rose-100 text-rose-700 border-rose-200',
                        'Date': 'bg-indigo-100 text-indigo-700 border-indigo-200',
                        'Business': 'bg-amber-100 text-amber-700 border-amber-200',
                        'Media': 'bg-orange-100 text-orange-700 border-orange-200',
                        'Servicii': 'bg-teal-100 text-teal-700 border-teal-200',
                        'Sanatate': 'bg-green-100 text-green-700 border-green-200',
                        'Educatie': 'bg-violet-100 text-violet-700 border-violet-200',
                        'Finante': 'bg-yellow-100 text-yellow-700 border-yellow-200',
                        'Legal': 'bg-slate-100 text-slate-700 border-slate-200',
                        'Design': 'bg-fuchsia-100 text-fuchsia-700 border-fuchsia-200',
                      };
                      const catClass = catColors[job.category] || 'bg-slate-100 text-slate-600 border-slate-200';
                      return (
                        <motion.button
                          key={job.id}
                          layout
                          initial={{ opacity: 0, scale: 0.95 }}
                          animate={{ opacity: 1, scale: 1 }}
                          exit={{ opacity: 0, scale: 0.95 }}
                          onClick={() => handleJobSelect(job)}
                          className="w-full p-3 md:p-5 rounded-xl md:rounded-2xl border border-slate-200 bg-white hover:border-indigo-300 hover:shadow-lg text-left transition-all group flex flex-col"
                        >
                          <div className="flex items-center justify-between mb-3">
                            <span className={`text-[10px] font-bold uppercase tracking-wider px-2.5 py-0.5 rounded-full border ${catClass}`}>
                              {job.category}
                            </span>
                            <span className={`text-[10px] font-bold px-2 py-0.5 rounded-full ${job.automationRisk > 80 ? 'bg-rose-100 text-rose-600' : job.automationRisk > 50 ? 'bg-amber-100 text-amber-600' : 'bg-green-100 text-green-600'}`}>
                              {job.level === 'critical' ? '🔴 Critic' : job.level === 'high' ? '🟠 Ridicat' : '🟡 Moderat'}
                            </span>
                          </div>
                          <h3 className="text-sm md:text-base font-bold text-slate-800 mb-1 group-hover:text-indigo-600 transition-colors">
                            {job.title}
                          </h3>
                          <ul className="text-[10px] md:text-xs text-slate-600 space-y-1 md:space-y-1.5 mb-2 md:mb-3">
                            <li className="flex gap-1.5"><span className="text-indigo-400">1.</span> {job.pivot1}</li>
                            <li className="flex gap-1.5"><span className="text-indigo-400">2.</span> {job.pivot2}</li>
                            <li className="flex gap-1.5"><span className="text-indigo-400">3.</span> {job.pivot3}</li>
                            <li className="flex gap-1.5"><span className="text-indigo-400">4.</span> {job.pivot4}</li>
                            <li className="flex gap-1.5"><span className="text-indigo-400">5.</span> {job.pivot5}</li>
                          </ul>
                          <div className="flex items-center gap-2 mb-3">
                            <div className="flex-1 bg-slate-100 h-1.5 rounded-full overflow-hidden">
                              <motion.div 
                                initial={{ width: 0 }}
                                animate={{ width: `${job.automationRisk}%` }}
                                className={`h-full rounded-full ${job.automationRisk > 80 ? 'bg-gradient-to-r from-rose-400 to-pink-500' : job.automationRisk > 50 ? 'bg-gradient-to-r from-amber-400 to-orange-500' : 'bg-gradient-to-r from-emerald-400 to-green-500'}`}
                              />
                            </div>
                            <span className="text-[10px] font-bold text-slate-400">{job.automationRisk}%</span>
                          </div>
                          <div
                            className="mt-auto w-full text-center py-2 rounded-xl bg-gradient-to-r from-blue-500 to-blue-600 text-white text-xs font-bold hover:from-blue-600 hover:to-blue-700 transition-all"
                            onClick={(e) => { e.stopPropagation(); handleJobSelect(job); }}
                          >
                            🚀 Lansează proiect — $9
                          </div>
                        </motion.button>
                      );
                    })}
                  </AnimatePresence>
                </div>
              </div>
            </div>
          ) : (
            <div className="relative max-w-5xl mx-auto bg-white md:rounded-[3rem] shadow-2xl md:border border-slate-200 overflow-visible md:overflow-hidden flex flex-col min-h-screen md:h-[90vh]">
              {/* Header with Back Button */}
              <div className="p-4 md:p-6 border-b border-slate-100 flex items-center justify-between bg-white sticky top-0 z-20 shadow-sm">
                <button 
                  onClick={() => { setSelectedJob(null); setPivotData(null); }}
                  className="flex items-center gap-1.5 text-indigo-600 font-black px-3 py-2 md:px-6 md:py-3 bg-indigo-50 hover:bg-indigo-100 transition-colors rounded-full text-sm"
                >
                  <ArrowLeft className="w-4 h-4 md:w-5 md:h-5" /> <span>Înapoi</span>
                </button>
                <div className="font-black text-slate-900 text-sm md:text-xl text-right truncate ml-2">{selectedJob.title}</div>
              </div>

              <div className="flex-1 overflow-visible md:overflow-y-auto p-4 md:p-12 relative">
                {isGenerating ? (
                  <div className="max-w-4xl mx-auto pb-32 w-full animate-pulse">
                    <div className="flex items-center justify-between mb-12">
                      <div className="p-6 bg-indigo-50 rounded-3xl border-2 border-indigo-100 w-full md:w-2/3">
                        <div className="h-4 bg-indigo-200 rounded w-1/4 mb-4"></div>
                        <div className="h-8 bg-indigo-200 rounded w-3/4"></div>
                      </div>
                    </div>
                    
                    <div className="space-y-6 mb-16">
                      <div className="h-10 bg-slate-200 rounded w-1/3 mb-8"></div>
                      <div className="h-4 bg-slate-200 rounded w-full"></div>
                      <div className="h-4 bg-slate-200 rounded w-full"></div>
                      <div className="h-4 bg-slate-200 rounded w-5/6"></div>
                      <div className="h-4 bg-slate-200 rounded w-full mt-8"></div>
                      <div className="h-4 bg-slate-200 rounded w-4/5"></div>
                      <div className="h-4 bg-slate-200 rounded w-full"></div>
